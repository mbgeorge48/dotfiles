#!/usr/bin/env bash
# scripts/shell

set -euo pipefail
cd "$(dirname "$0")/.."

ARCHIVE_DIR="$HOME/.dotfiles/archive"
mkdir -p "$ARCHIVE_DIR"

echo "🐚 Configuring Shell Environment..."

# 1. Main Entry Point: Map your existing 'profile' asset straight to ~/.zshrc
if [[ -e "$HOME/.zshrc" && ! -L "$HOME/.zshrc" ]]; then
    echo "🎒 Archiving local .zshrc..."
    mv "$HOME/.zshrc" "$ARCHIVE_DIR/zshrc.bak" 2>/dev/null || true
fi

echo "🔗 Symlinking shell/profile to ~/.zshrc..."
ln -sf "$HOME/.dotfiles/shell/profile" "$HOME/.zshrc"

# 2. Seed the local untracked override file so the profile line doesn't error out
if [[ ! -f "$HOME/.zshrc.local" ]]; then
    echo "📝 Creating local ~/.zshrc.local file..."
    touch "$HOME/.zshrc.local"
fi

echo "✅ Shell entry points symlinked successfully!"