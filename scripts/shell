#!/usr/bin/env bash

set -euo pipefail
cd "$(dirname "$0")/.."

ARCHIVE_DIR="$HOME/.dotfiles/archive"
mkdir -p "$ARCHIVE_DIR"

source scripts/common

ACTION="${1:-}"
if [[ "$ACTION" == "setup" ]]; then
    echo "Setting up shell configuration for $PLATFORM..."

    # Archive old files if they exist
    for f in ~/.zprofile ~/.bash_profile ~/.zsh_prompt ~/.bash_prompt ~/.zshrc ~/.bashrc; do
        if [[ -s "$f" ]]; then
            echo "Archiving $f → $ARCHIVE_DIR"
            mv "$f" "$ARCHIVE_DIR/" 2>/dev/null || true
        fi
    done

    # Ensure zsh is installed
    install_package zsh
    ZSH_PATH="$(which zsh)"

    # Change default shell if not already zsh
    if [[ "$SHELL" != "$ZSH_PATH" ]]; then
        chsh -s "$ZSH_PATH" 2>/dev/null || echo "⚠️ Could not change shell. You may need to do it manually."
    fi

    # Dotfiles shell profile
    DOT_PROFILE="$HOME/.dotfiles/shell/profile"
    if [[ ! -f "$DOT_PROFILE" ]]; then
        echo "⚠️ Warning: $DOT_PROFILE not found."
    fi
    SOURCE_CMD="source $DOT_PROFILE"

    # Ensure zshrc exists and source the dotfiles profile
    ZSHRC="$HOME/.zshrc"
    touch "$ZSHRC"
    if ! grep -Fxq "$SOURCE_CMD" "$ZSHRC"; then
        echo "$SOURCE_CMD" >> "$ZSHRC"
        echo "Added shell profile source to $ZSHRC"
    else
        echo "Shell profile source already present in $ZSHRC"
    fi

    # On WSL, force Bash to launch zsh (but profile sourcing happens in .zshrc)
    if [[ "$PLATFORM" == "wsl" ]]; then
        BASHRC="$HOME/.bashrc"
        touch "$BASHRC"
        if ! grep -Fxq "exec $ZSH_PATH" "$BASHRC"; then
            echo "exec $ZSH_PATH" >> "$BASHRC"
            echo "Added 'exec zsh' to $BASHRC for WSL"
        fi
    fi

    # Optionally append source command to Bash rc on mac/Linux if desired
    if [[ "$PLATFORM" != "wsl" ]]; then
        BASHRC="$HOME/.bashrc"
        touch "$BASHRC"
        if ! grep -Fxq "$SOURCE_CMD" "$BASHRC"; then
            echo "$SOURCE_CMD" >> "$BASHRC"
            echo "Added shell profile source to $BASHRC"
        else
            echo "Shell profile source already present in $BASHRC"
        fi
    fi
fi

if [[ "${1:-}" == "update" ]]; then
    echo "🔄 Updating shell-related packages for $PLATFORM..."
    case "$PLATFORM" in
    mac)
        brew update
        ;;
    linux | wsl)
        sudo apt-get update -y
        ;;
    windows)
        echo "Windows shell updates are handled via Chocolatey or manually."
        ;;
    esac
fi
