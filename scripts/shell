#!/usr/bin/env bash

set -euo pipefail
cd "$(dirname "$0")/.."

ARCHIVE_DIR="$HOME/.dotfiles/archive"
mkdir -p "$ARCHIVE_DIR"

source scripts/common

ACTION="${1:-}"
if [[ "$ACTION" == "setup" ]]; then
    echo "Setting up shell configuration for $PLATFORM..."

    # Archive old files if they exist
    for f in ~/.zprofile ~/.bash_profile ~/.zsh_prompt ~/.bash_prompt ~/.zshrc ~/.bashrc; do
        if [[ -s "$f" ]]; then
            echo "Archiving $f → $ARCHIVE_DIR"
            mv "$f" "$ARCHIVE_DIR/" 2>/dev/null || true
        fi
    done

    # Dotfiles shell profile
    DOT_PROFILE="$HOME/.dotfiles/shell/profile"
    if [[ ! -f "$DOT_PROFILE" ]]; then
        echo "⚠️ Warning: $DOT_PROFILE not found."
    fi
    SOURCE_CMD="source $DOT_PROFILE"

    # Determine default shell
    DEFAULT_SHELL="$(basename "${SHELL:-bash}")"

    case "$DEFAULT_SHELL" in
        zsh)
            RC_FILE="$HOME/.zshrc"
            ;;
        bash|sh|*)
            RC_FILE="$HOME/.bashrc"
            ;;
    esac

    # Ensure the rc file exists
    touch "$RC_FILE"

    # Append the source command if not already present
    if ! grep -Fxq "$SOURCE_CMD" "$RC_FILE"; then
        echo "$SOURCE_CMD" >>"$RC_FILE"
        echo "Added shell profile source to $RC_FILE"
    else
        echo "Shell profile source already present in $RC_FILE"
fi
fi

if [[ "${1:-}" == "update" ]]; then
    echo "🔄 Updating shell-related packages for $PLATFORM..."
    case "$PLATFORM" in
    mac)
        brew update
        ;;
    linux | wsl)
        sudo apt-get update -y
        ;;
    windows)
        echo "Windows shell updates are handled via Chocolatey or manually."
        ;;
    esac
fi
