#!/bin/bash

set -euo pipefail
cd "$(dirname "$0")/.."
ACTION="${1:-}"

ARCHIVE_DIR="$HOME/.dotfiles/archive"
mkdir -p "$ARCHIVE_DIR"

if ! [ -x "$(command -v vim)" ]; then
    echo "Requires Vim to be installed"
    exit 1
fi

if [[ "$ACTION" == "setup" ]]; then
    if [ -s $HOME/.vimrc ]; then
        mv $HOME/.vimrc "$ARCHIVE_DIR/" 2>/dev/null
    fi

    if [ -L $HOME/.vimrc ]; then
        rm $HOME/.vimrc
    fi
    ln -s $HOME/.dotfiles/vim/vimrc ~/.vimrc
fi
