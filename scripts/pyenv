#!/usr/bin/env bash
# scripts/pyenv

set -euo pipefail
cd "$(dirname "$0")/.."

ARCHIVE_DIR="$HOME/.dotfiles/archive"
mkdir -p "$ARCHIVE_DIR"

# Pull in PLATFORM detection and the install_package function
source scripts/common

if ! command -v pyenv >/dev/null 2>&1; then
    echo "Installing pyenv..."

    if [[ "$PLATFORM" == "mac" ]]; then
        # Homebrew cleanly handles everything on Mac natively
        install_package pyenv
    else
        # Linux / WSL require core C-compilation header libraries first
        echo "🐳 Installing WSL build dependencies..."
        install_package build-essential libssl-dev zlib1g-dev libbz2-dev \
            libreadline-dev libsqlite3-dev wget curl llvm libncurses5-dev \
            libncursesw5-dev xz-utils tk-dev libffi-dev liblzma-dev

        # Use the official installer instead of a raw git clone for faster/cleaner setup
        if [ ! -d "$HOME/.pyenv" ]; then
            echo "📥 Downloading official pyenv engine..."
            curl https://pyenv.run | bash
        fi
    fi
fi
