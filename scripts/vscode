#!/usr/bin/env bash

set -euo pipefail
cd "$(dirname "$0")/.."
ACTION="${1:-}"

ARCHIVE_DIR="$HOME/.dotfiles/archive"
mkdir -p "$ARCHIVE_DIR"

if ! command -v code >/dev/null 2>&1; then
    echo "VS Code CLI 'code' not found. Please install VS Code first."
    exit 1
fi

DOT_VSCODE="$HOME/.dotfiles/vscode"
if [[ "$ACTION" == "setup" ]]; then
    if [[ "$PLATFORM" == "mac" ]]; then
        SETTINGS_DIR="$HOME/Library/Application Support/Code/User"
        SETTINGS_FILE="$SETTINGS_DIR/settings.json"
        mkdir -p "$SETTINGS_DIR"

        # Archive existing settings
        if [[ -e "$SETTINGS_FILE" ]]; then
            mv "$SETTINGS_FILE" "$ARCHIVE_DIR/" 2>/dev/null || true
        fi

        # Symlink settings
        ln -sf "$DOT_VSCODE/settings.json" "$SETTINGS_FILE"
        echo "Linked VS Code settings to $SETTINGS_FILE"

    elif [[ "$PLATFORM" == "linux" || "$PLATFORM" == "wsl" ]]; then
        echo "Non-macOS systems require manual VS Code settings symlink:"
        if [[ "$PLATFORM" == "linux" ]]; then
            echo "Linux: ~/.config/Code/User/settings.json"
        else
            echo "WSL: /mnt/c/Users/USERNAME/AppData/Roaming/Code/User/settings.json"
        fi
    fi
fi

EXT_FILE="$DOT_VSCODE/extensions"
if [[ "$ACTION" == "sync" ]]; then
    # Dump current extensions to vscode/extensions
    code --list-extensions >"$EXT_FILE"
    echo "Saved current extensions to $EXT_FILE"
else
    if [[ -f "$EXT_FILE" ]]; then
        echo "Installing VSCode extensions from $EXT_FILE..."
        while read -r line; do
            # Skip empty lines and comments
            [[ -z "$line" || "$line" =~ ^# ]] && continue
            eval "$line"
        done < "$EXT_FILE"
    fi
fi
