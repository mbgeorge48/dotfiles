#!/usr/bin/env bash
# scripts/vscode

set -euo pipefail
cd "$(dirname "$0")/.."

ARCHIVE_DIR="$HOME/.dotfiles/archive"
mkdir -p "$ARCHIVE_DIR"

# Pull in your branch's platform detection code
source scripts/common

echo "⚙️ Configuring VS Code..."

# 1. Determine where settings.json needs to be dropped based on the OS
if [[ "$PLATFORM" == "mac" ]]; then
    VSCODE_SETTING_DIR="$HOME/Library/Application Support/Code/User"
    VSCODE_SETTING_PATH="$VSCODE_SETTING_DIR/settings.json"

elif [[ "$PLATFORM" == "wsl" ]]; then
    # Reach into the Windows host filesystem from inside WSL
    # This safely grabs your active Windows username without hardcoding it
    WIN_USER=$(cmd.exe /c "echo %USERNAME%" 2>/dev/null | tr -d '\r')
    VSCODE_SETTING_DIR="/mnt/c/Users/$WIN_USER/AppData/Roaming/Code/User"
    VSCODE_SETTING_PATH="$VSCODE_SETTING_DIR/settings.json"

else
    echo "⏭️ Skipping VS Code sync for platform: $PLATFORM"
    exit 0
fi

# 2. Safely back up any existing settings so you don't lose anything
if [ -s "$VSCODE_SETTING_PATH" ]; then
    echo "🎒 Backing up existing VS Code settings..."
    mv "$VSCODE_SETTING_PATH" "$ARCHIVE_DIR/settings.json.bak"
fi

# 3. Copy/Link your dotfiles settings into place
mkdir -p "$VSCODE_SETTING_DIR"
if [[ "$PLATFORM" == "mac" ]]; then
    ln -sf "$HOME/.dotfiles/vscode/settings.json" "$VSCODE_SETTING_PATH"
    echo "✅ VS Code settings synchronized."
elif [[ "$PLATFORM" == "wsl" ]]; then
    # Symbolic links don't work well across the WSL/Windows boundary, so we copy instead
    cp vscode/settings.json "$VSCODE_SETTING_PATH"
    echo "✅ VS Code settings copied into place."
fi


# 4. Install Extensions
if command -v code >/dev/null 2>&1; then
    echo "📦 Syncing tracked VS Code extensions..."

    # Read extensions line-by-line, ignoring comments or empty lines
    if [ -f "vscode/extensions" ]; then
        while read -r ext || [ -n "$ext" ]; do
            # Strip spaces, skip empty lines or commented line marks
            ext=$(echo "$ext" | tr -d '\r ' )
            if [[ -n "$ext" && ! "$ext" =~ ^# ]]; then
                # Run the installer silently. If it crashes, catch the error stream 
                # and filter out the noisy node deprecation warnings.
                if ! output=$(code --install-extension "$ext" 2>&1 >/dev/null); then
                    echo "  ❌ Failed to install: $ext"
                    echo "$output" | grep -v -E "DeprecationWarning|node:"
                fi
            fi
        done < vscode/extensions
    fi

    # Keep your environment isolated: automatically add WSL remote context layer
    if [[ "$PLATFORM" == "wsl" ]]; then
        echo "🐳 Ensuring WSL Remote extension is active on host..."
        cmd.exe /c "code --install-extension ms-vscode-remote.remote-wsl" >/dev/null 2>&1 || true
    fi
    echo "✅ VS Code extension sync complete."
else
    echo "⚠️ 'code' command line utility not found. Skipping extension installations."
fi

echo "✅ VS Code configuration complete!"
