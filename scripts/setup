#!/bin/bash

set -euo pipefail
cd "$(dirname "$0")/.."

# Detect platform
if grep -qi microsoft /proc/version; then
    PLATFORM="wsl"
elif [[ "$OSTYPE" == "darwin"* ]]; then
    PLATFORM="mac"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    PLATFORM="linux"
else
    PLATFORM="windows"
fi
echo "Detected platform: $PLATFORM"

mkdir -p ~/personal/

if [ "$PLATFORM" = "mac" ]; then
    echo "### Brew ###"
    scripts/brew
fi

echo "### Shell ###"
scripts/shell update
scripts/shell setup

echo "### Git ###"
scripts/git setup

if [ "$1" == "work" ]; then
    mkdir -p ~/work/
    custom_aliases=".custom_aliases"
    if [ -s ~/$custom_aliases ]; then
        touch ~/.custom_aliases
    fi
    echo "### Work Git ###"
    scripts/git work
fi

echo "Vim"
scripts/vim setup

echo "VScode"
scripts/vscode setup

if ! [ "$(uname -s)" = "Darwin" ]; then
    echo "Pyenv"
    scripts/pyenv
    echo "NPM"
    scripts/npm

fi

echo "GPG"
scripts/gpg
echo "SSH"
scripts/ssh

if ! [ -L ~/personal/dotfiles ]; then
    ln -s ~/.dotfiles ~/personal/dotfiles
fi

exec $SHELL
