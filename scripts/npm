#!/usr/bin/env bash
# scripts/npm

echo "🚀 Setting up Node environment..."

# 1. Install fnm (Fast Node Manager) if it's missing
if ! command -v fnm &> /dev/null; then
    echo "Installing fnm..."
    curl -fsSL https://fnm.vercel.app/install | bash

    # Manually configure paths temporarily so the script can use fnm immediately
    export PATH="$HOME/.local/share/fnm:$PATH"
    eval "$(fnm env)"
else
    echo "✅ fnm is already installed."
fi

# 2. Install and set the latest LTS version of Node
echo "📦 Installing Node.js LTS..."
fnm install --lts
fnm use default

# 3. Enable Corepack to cleanly activate pnpm
# (Corepack comes bundled with Node, meaning no heavy global npm installs needed!)
echo "⚡ Activating pnpm via Corepack..."
corepack enable
corepack prepare pnpm@latest --activate

echo "✅ Node, fnm, and pnpm setup complete!"
