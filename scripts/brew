#!/usr/bin/env bash
# scripts/brew

set -euo pipefail
cd "$(dirname "$0")/.."
ACTION="${1:-}"

# Load platform detection rules
source scripts/common

if [[ "$PLATFORM" != "mac" ]]; then
    echo "⏭️ Skipping Homebrew setup: script only runs on Mac."
    exit 0
fi

# Determine the absolute repository path root safely
DOTFILES_ROOT="$(pwd)"
BREW_DIR="$DOTFILES_ROOT/brew"

# Install Brew automatically if missing during a raw deployment setup
if ! command -v brew >/dev/null 2>&1; then
    if [[ "$ACTION" == "setup" ]]; then
        echo "🍺 Installing Homebrew from scratch..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        
        # Determine CPU architecture path for modern Apple Silicon support vs Intel legacy
        if [[ -f "/opt/homebrew/bin/brew" ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        elif [[ -f "/usr/local/bin/brew" ]]; then
            eval "$(/usr/local/bin/brew shellenv)"
        fi
    else
        echo "❌ Homebrew is missing. Re-run this module with the 'setup' argument."
        exit 1
    fi
fi

# Orchestrate packages matching your tracking logs
if [[ "$ACTION" == "sync" ]]; then
    echo "🔄 Freezing your active Mac applications to your Brewfile..."
    brew bundle dump --file "$BREW_DIR/Brewfile" --force
else
    echo "📦 Synchronizing and upgrading your Mac software ecosystem..."
    brew update
    brew upgrade
    brew bundle --file "$BREW_DIR/Brewfile"
fi

echo "✅ Mac Homebrew pipeline complete!"