#!/bin/sh

set -euo pipefail
cd "$(dirname "$0")/.."
ACTION="${1:-}"

if ! [ "$PLATFORM" = "mac" ]; then
    echo "Error: script only runs on Mac"
    exit 1
fi

# Install Brew if missing
if ! command -v brew >/dev/null 2>&1; then
    if [ "$ACTION" = "setup" ]; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        eval "$(brew shellenv)"
    else
        echo "Brew is required. Run with 'setup' first."
        exit 1
    fi
fi

BREW_DIR="$(dirname "$0")/../brew"

if [ "$ACTION" = "sync" ]; then
    brew bundle dump --file "$BREW_DIR/Brewfile" --force
else
    brew update
    brew upgrade
    brew bundle --file "$BREW_DIR/Brewfile"
fi
