# shell/profile

export PATH="$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS-Specific: Only run Homebrew logic on a Mac
    if [ -f "/opt/homebrew/bin/brew" ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi

    # OpenSSL compiler flags
    export CPPFLAGS="-I/usr/local/opt/openssl/include"
    export LDFLAGS="-L/usr/local/opt/openssl/lib"

    # Android SDK & Java paths
    ANDROID_HOME="$HOME/Library/Android/sdk"
    [ -d "$ANDROID_HOME" ] && export PATH="$ANDROID_HOME/platform-tools:$PATH"

    JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
    [ -d "$JAVA_HOME" ] && export JAVA_HOME
else
    # WSL / Linux-Specific: Ensure Windows interop tools run smoothly
    export DISPLAY=:0
fi

# Python
if [ -d "$HOME/.pyenv" ]; then
    export PYENV_ROOT="$HOME/.pyenv"
    export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)"
fi
# Python Auto-Venv Hook
[[ -f "$HOME/.dotfiles/python/python" ]] && source "$HOME/.dotfiles/python/python"

# Node
[[ -f "$HOME/.dotfiles/node/fnm" ]] && source "$HOME/.dotfiles/node/fnm"
if command -v fnm &> /dev/null; then
    eval "$(fnm env --use-on-cd --log-level=error --shell zsh)"
fi

# GPG Setup (Crucial for Git commit signing)
if command -v tty >/dev/null 2>&1; then
    export GPG_TTY=$(tty)
fi

# Global Editors
export VISUAL=vim
export EDITOR="$VISUAL"



# ~/.zshrc
[[ -f ~/.zprofile ]] && source ~/.zprofile

[[ -f ~/.dotfiles/shell/aliases ]]    && source ~/.dotfiles/shell/aliases
[[ -f ~/.dotfiles/shell/zsh_prompt ]] && source ~/.dotfiles/shell/zsh_prompt
[[ -f ~/.dotfiles/shell/zsh_extras ]] && source ~/.dotfiles/shell/zsh_extras
# Load local-only machine overrides if they exist
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
