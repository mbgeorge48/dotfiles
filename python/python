# python/python

# 1. Initialize Pyenv Context
if [ -d "$HOME/.pyenv" ]; then
    export PYENV_ROOT="$HOME/.pyenv"
    export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)"
fi

# 2. Local virtual environment auto-switching function
function auto_activate_python_venv() {
    # Check for a standard, local layout folder (.venv)
    if [ -d ".venv" ]; then
        if [[ "$VIRTUAL_ENV" != "$(pwd)/.venv" ]]; then
            source .venv/bin/activate
            echo "🐍 Activated $(python -V) environment"
        fi
    # Stand down smoothly if we step away from the repository root
    elif [ ! -z "$VIRTUAL_ENV" ]; then
        if [[ "$PWD" != "$(dirname "$VIRTUAL_ENV")"* ]]; then
            deactivate 2>/dev/null
        fi
    fi
}

# Queue the directory change hook safely using the Zsh array framework
if [[ -n "$ZSH_VERSION" ]]; then
    typeset -ag chpwd_functions
    if [[ "${chpwd_functions[(r)auto_activate_python_venv]}" != "auto_activate_python_venv" ]]; then
        chpwd_functions+=auto_activate_python_venv
    fi
fi